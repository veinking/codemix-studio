# bIDE by CodeMix environment template
# Copy this file to .env and replace placeholders with buyer-owned credentials.
# Do not commit real secrets. No live Supabase, Stripe, OpenAI, or AI gateway credentials are included.

# Optional Supabase frontend config (required for auth, cloud save/share, usage limits, payments UI)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key

# Optional deployment metadata
VITE_PUBLIC_SITE_URL=https://bideide.com

# Supabase Edge Function secrets (set in Supabase dashboard, not in Vite frontend env)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-server-only

# AI provider/gateway secrets for Edge Functions only
OPENAI_API_KEY=your-openai-api-key-server-only
LOVABLE_API_KEY=your-ai-gateway-key-server-only

# Stripe secrets for Edge Functions only
STRIPE_SECRET_KEY=your-stripe-secret-key-server-only
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your_monthly_pro_plan
